   "source": [
    "# Early vLLM Smoke Test (Day 3)\n",
    "**Objective:** Ensure that vLLM can successfully load the FP16/GPTQ version of `LLama-3-8B-Tele-it` on a T4 GPU without OOM errors, and confirm that latency is acceptable (< 4s).\n",
    "**Bottleneck Mitigation #3**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install vllm transformers accelerate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from vllm import LLM, SamplingParams\n",
    "import time\n",
    "\n",
    "model_id = \"AliMaatouk/LLama-3-8B-Tele-it\"\n",
    "# Note: On Kaggle T4, setting dtype='half' and max_model_len=4096 is crucial to fit in 16GB VRAM\n",
    "print(f\"Loading {model_id} with vLLM...\")\n",
    "start_time = time.time()\n",
    "llm = LLM(model=model_id, dtype='half', max_model_len=4096, gpu_memory_utilization=0.9)\n",
    "print(f\"Model loaded in {time.time() - start_time:.2f} seconds\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "prompts = [\n",
    "    \"What is RRC connection reconfiguration in 5G?\",\n",
    "    \"Explain the difference between SA and NSA architectures.\",\n",
    "    \"How does HARQ work in the MAC layer?\"\n",
    "]\n",
    "sampling_params = SamplingParams(temperature=0.1, max_tokens=256, stop_token_ids=[128001, 128009])\n",
    "\n",
    "print(\"Running inference...\")\n",
    "start_time = time.time()\n",
    "outputs = llm.generate(prompts, sampling_params)\n",
    "end_time = time.time()\n",
    "\n",
    "print(f\"\\nGenerated {len(prompts)} responses in {end_time - start_time:.2f} seconds\")\n",
    "print(f\"Average Latency: {(end_time - start_time) / len(prompts):.2f} seconds per query\")\n",
    "\n",
    "for output in outputs:\n",
    "    print(\"\\n---\")\n",
    "    print(f\"Prompt: {output.prompt}\")\n",
    "    print(f\"Response: {output.outputs[0].text}\")"
   ]
  }
 ],
